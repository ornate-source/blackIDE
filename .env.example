# Black IDE — environment variables
#
# Copy to `.env` and fill in values for local builds and release scripts:
#     cp .env.example .env
#
# `.env` is gitignored. NEVER commit real values.
#
# NOTE: GitHub Actions secrets are write-only — their values cannot be read back
# from GitHub by anyone, including the repo owner. Values below must come from
# your own records or be regenerated at the source.

# ─── Release automation ───────────────────────────────────────────────────────
# Used by scripts/release/update-releases.js, update_version.sh, ci/check_tags.sh
# In CI, GITHUB_TOKEN is injected automatically by Actions.
# A PAT is only needed for local runs or cross-repo pushes.
GH_TOKEN=
GITHUB_TOKEN=

# Elevated PAT for workflows that push to other repositories.
# Set in GitHub Actions secrets.
STRONGER_GITHUB_TOKEN=

# ─── Snap Store (Linux publishing) ────────────────────────────────────────────
SNAP_STORE_LOGIN=
SNAP_STORE_CHANNEL=

# ─── macOS code signing & notarization ────────────────────────────────────────
# See scripts/dev/osx/codesign.env.template
# Referenced by workflows but NOT currently set in GitHub secrets.
CERTIFICATE_OSX_APPLE_ID=
CERTIFICATE_OSX_APP_PASSWORD=
CERTIFICATE_OSX_P12_DATA=
CERTIFICATE_OSX_P12_PASSWORD=
CERTIFICATE_OSX_TEAM_ID=

# ─── Windows code signing (SignPath) ──────────────────────────────────────────
# Referenced by workflows but NOT currently set in GitHub secrets.
SIGNPATH_API_TOKEN=
SIGNPATH_ORGANIZATION_ID=
SIGNPATH_PROJECT_SLUG=
SIGNPATH_POLICY_SLUG=

# ─── Linux package signing (GPG) ──────────────────────────────────────────────
# Referenced by workflows but NOT currently set in GitHub secrets.
GPG_PRIVATE_KEY=
GPG_PASSPHRASE=

# ─── Arch User Repository publishing ──────────────────────────────────────────
# Referenced by workflows but NOT currently set in GitHub secrets.
AUR_USERNAME=
AUR_EMAIL=
AUR_PRIVATE_KEY=

# ─── GitLab Pages mirror ──────────────────────────────────────────────────────
# Referenced by workflows but NOT currently set in GitHub secrets.
GL_PAGES_TOKEN=
