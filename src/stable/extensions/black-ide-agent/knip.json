{
  "$schema": "https://unpkg.com/knip@next/schema.json",
  "workspaces": {
    ".": {
      "project": ["src/**/*.ts"]
    },
    "webview": {
      "project": ["src/**/*.{ts,tsx}"]
    }
  },
  "ignoreDependencies": ["stylelint-no-unsupported-browser-features", "playwright"],
  "rules": {
    "types": "off"
  }
}
