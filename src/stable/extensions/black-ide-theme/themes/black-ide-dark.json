{
  "name": "Black IDE Dark",
  "colors": {
    "editor.background": "#000000",
    "editor.foreground": "#f8f8f2",
    "editor.lineHighlightBackground": "#0d0d0d",
    "editorCursor.foreground": "#00e5ff",
    "editor.selectionBackground": "#1e1e3f",
    "editor.inactiveSelectionBackground": "#15152a",
    "editor.selectionHighlightBackground": "#1e1e3f80",
    "editorLineNumber.foreground": "#4b526d",
    "editorLineNumber.activeForeground": "#00e5ff",
    
    "sideBar.background": "#050505",
    "sideBar.foreground": "#a9b1d6",
    "sideBar.border": "#121214",
    "sideBarTitle.foreground": "#00e5ff",
    "sideBarSectionHeader.background": "#080808",
    "sideBarSectionHeader.foreground": "#7aa2f7",
    "sideBarSectionHeader.border": "#121214",
    
    "activityBar.background": "#000000",
    "activityBar.foreground": "#00e5ff",
    "activityBar.inactiveForeground": "#4b526d",
    "activityBar.border": "#121214",
    "activityBarBadge.background": "#bd93f9",
    "activityBarBadge.foreground": "#000000",
    "activityBar.activeBorder": "#00e5ff",
    
    "tab.activeBackground": "#000000",
    "tab.activeForeground": "#00e5ff",
    "tab.activeBorder": "#00e5ff",
    "tab.inactiveBackground": "#050505",
    "tab.inactiveForeground": "#787c99",
    "tab.border": "#121214",
    
    "editorGroupHeader.tabsBackground": "#050505",
    "editorGroupHeader.tabsBorder": "#121214",
    
    "statusBar.background": "#000000",
    "statusBar.foreground": "#a9b1d6",
    "statusBar.border": "#121214",
    "statusBar.debuggingBackground": "#bd93f9",
    "statusBar.debuggingForeground": "#000000",
    "statusBar.noFolderBackground": "#000000",
    
    "titleBar.activeBackground": "#000000",
    "titleBar.activeForeground": "#f8f8f2",
    "titleBar.inactiveBackground": "#050505",
    "titleBar.inactiveForeground": "#787c99",
    "titleBar.border": "#121214",
    
    "list.activeSelectionBackground": "#1e1e2f",
    "list.activeSelectionForeground": "#00e5ff",
    "list.inactiveSelectionBackground": "#0e0e1a",
    "list.inactiveSelectionForeground": "#bd93f9",
    "list.hoverBackground": "#0c0c14",
    "list.highlightForeground": "#00e5ff",
    
    "input.background": "#080808",
    "input.foreground": "#f8f8f2",
    "input.border": "#1c1c24",
    "inputOption.activeBorder": "#00e5ff",
    
    "button.background": "#bd93f9",
    "button.foreground": "#000000",
    "button.hoverBackground": "#a370f7",
    
    "terminal.background": "#000000",
    "terminal.foreground": "#f8f8f2",
    "terminal.ansiBlack": "#000000",
    "terminal.ansiRed": "#ff5555",
    "terminal.ansiGreen": "#50fa7b",
    "terminal.ansiYellow": "#f1fa8c",
    "terminal.ansiBlue": "#bd93f9",
    "terminal.ansiMagenta": "#ff79c6",
    "terminal.ansiCyan": "#8be9fd",
    "terminal.ansiWhite": "#f8f8f2"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6272a4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#f1fa8c"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#bd93f9"
      }
    },
    {
      "scope": [
        "variable",
        "variable.parameter",
        "variable.other"
      ],
      "settings": {
        "foreground": "#f8f8f2"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ff79c6"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#50fa7b"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml"
      ],
      "settings": {
        "foreground": "#ff79c6"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#50fa7b",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#8be9fd"
      }
    }
  ]
}
